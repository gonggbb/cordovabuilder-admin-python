# ============================================
# CordovaBuilder Admin Python - 环境变量配置示例
# ============================================
# 使用方法:
# 1. 复制此文件为 .env
# 2. 根据需要修改配置值
# 3. 重启服务使配置生效
#
# 配置加载优先级:
# 1. 系统环境变量（最高优先级）
# 2. .env 文件
# 3. 代码中的默认值（最低优先级）

# ============================================
# 服务器配置
# ============================================
PORT=3000
CORS_ORIGINS=["*"]

# ============================================
# 日志配置
# ============================================
# 日志级别: DEBUG, INFO, WARNING, ERROR
# - DEBUG: 开发环境，输出详细日志
# - INFO: 生产环境推荐
# - WARNING: 仅输出警告和错误
# - ERROR: 仅输出错误信息
LOGURU_LEVEL=DEBUG

# ============================================
# 其他环境变量（会被脚本使用，Python 代码会忽略）
# ============================================
# NODE_HOME=./installed/node
# JAVA_HOME=./installed/java
# ANDROID_HOME=./installed/android-sdk
# GRADLE_HOME=./installed/gradle
# WORKSPACE_DIR=./workspace
