# ============================================
# Docker 构建忽略文件
# ============================================

# ============================================
# Python 缓存和编译文件
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.so

# ============================================
# 虚拟环境
# ============================================
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ============================================
# Poetry
# ============================================
.pypoetry/

# ============================================
# Git
# ============================================
.git/
.gitignore
.gitattributes

# ============================================
# IDE 配置
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
.spyderproject
.spyproject
.ropeproject

# ============================================
# 测试和覆盖率报告
# ============================================
tests/
.pytest_cache/
htmlcov/
.coverage
.coverage.*
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.tox/
.nox/

# ============================================
# 日志文件
# ============================================
logs/
*.log

# ============================================
# 临时文件和备份
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.tmp
*.bak
*.backup

# ============================================
# 文档
# ============================================
docs/
README.md
USE.md
LICENSE

# ============================================
# Node.js (前端已打包到 dist/)
# ============================================
node_modules/
package-lock.json
yarn.lock

# ============================================
# Docker 相关文件 (避免循环引用)
# ============================================
Dockerfile
docker-compose.yml
.dockerignore

# 注意：start-container.sh 需要保留，因为 Dockerfile 会复制它

# ============================================
# 其他不必要的文件
# ============================================
*.md
Makefile

# ============================================
# Windows 特定文件
# ============================================
*.exe
*.dll
*.bat
*.cmd