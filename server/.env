# ============================================
# CordovaBuilder Admin Python - 本地开发环境配置
# ============================================
# 此文件用于本地开发，不会被 Git 跟踪

# ============================================
# 服务器配置
# ============================================
PORT=3000
CORS_ORIGINS=["*"]

# ============================================
# 日志配置
# ============================================
# 开发环境使用 DEBUG 级别
LOGURU_LEVEL=DEBUG

# ============================================
# 其他环境变量（可选）
# ============================================
# NODE_HOME=./installed/node
# JAVA_HOME=./installed/java
# ANDROID_HOME=./installed/android-sdk
# GRADLE_HOME=./installed/gradle
# WORKSPACE_DIR=./workspace
